[MASTER]
# Add or customize general pylint settings here
ignore=venv  # Example to ignore a virtual environment directory

[FORMAT]
# Set the maximum allowed line length
max-line-length = 100

# Ignore long lines if they match the specified patterns
ignore-long-lines = description=|"""=|"

[TYPECHECK]
generated-members="cv2.*"

[MESSAGES CONTROL]
# Disable specific messages by their IDs
disable=C0103,  # Variable name doesn't conform to snake_case
        C0114,  # Missing module docstring
        C0115,  # Missing class docstring
        C0116,  # Missing function docstring
        C0207,  # Similar to "bad practice" checks
        C0302,  # Too many lines in module
        E0213,  # Method should have self as first argument
        E0402,  # Import outside top-level
        E0401,  # Unable to import - REMOVE
        E0611,  # No name in module - REMOVE
        E1121,  # Too many positional arguments
        E1133,  # Invalid comparison is always true/false
        E1136,  # Value type inference issues
        R0902,  # Too many instance attributes
        R0903,  # Too few public methods in a class
        R0914,  # Too many local variables
        R0915,  # Too many statements in a function
        R0912,  # Too many branches in a function
        W0212,  # Access to a protected member
        W0718,  # Catching too general exception
        W0511,  # TODO/FIXME not found
        R0913,
        R0917,
        R0801,
        R1702,
        C0415,  # Import outside top-level
